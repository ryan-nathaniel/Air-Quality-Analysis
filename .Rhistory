annotation_name_rot = 90
)
# create an annotation dataframe for the rows
month_annotation <- rowAnnotation(
Month = as.character(df_clean$Month),
col = list(Month = c("5" = "lightblue", "6" = "lightgreen",
"7" = "lightpink", "8" = "wheat", "9" = "plum"))
)
# create the complex heatmap
Heatmap(heatmap_data,
name = "Z-score",
right_annotation = right_ha,
column_title = "Air Quality Variables",
show_row_names = FALSE,
right_annotation = month_annotation,
cluster_columns = TRUE,
cluster_rows = FALSE)
