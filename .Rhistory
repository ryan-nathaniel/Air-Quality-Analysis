library(ComplexHeatmap)
library(circlize)
# Sort data by Month and Day
df_clean <- df_clean[order(df_clean$Month, df_clean$Day), ]
# Scale the first 4 variables
heatmap_data <- scale(df_clean[, 1:4])
# Calculate average ozone for each month
mean_ozone <- tapply(df_clean$Ozone, df_clean$Month, mean, na.rm = TRUE)
# Repeat the monthly average ozone for each row/day
avg_ozone_each_row <- mean_ozone[as.character(df_clean$Month)]
# Create right annotation
right_ha <- rowAnnotation(
AvgOzone = anno_barplot(as.numeric(avg_ozone_each_row),
gp = gpar(fill = "gray70", col = "black"),
border = FALSE),
Month = as.character(df_clean$Month),
Day = anno_text(as.character(df_clean$Day),
gp = gpar(fontsize = 8)),
col = list(
Month = c("5" = "lightblue",
"6" = "lightgreen",
"7" = "lightpink",
"8" = "wheat",
"9" = "plum")
),
annotation_name_rot = 90
)
# Create heatmap
Heatmap(heatmap_data,
name = "Z-score",
right_annotation = right_ha,
column_title = "Air Quality Variables",
show_row_names = FALSE,
cluster_columns = TRUE,
cluster_rows = FALSE)
